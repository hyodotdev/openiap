# Copy this file to .env.local and fill in your own values.
# .env.local is git-ignored; this file is the committed template.
#
# Local development (`bun run dev`) reads `.env.local` and should use
# your DEV Convex deployment URL.
#
# Manual prod deploys (`bun run deploy:prod` → scripts/deploy-prod.sh)
# read `.env.production` instead, so the SPA bundle baked into the Fly
# image points at the PROD Convex deployment. `.env.production` is
# git-ignored too — copy the Convex-CLI-populated `.env.local` you'd
# use against prod, or just:
#
#   echo "VITE_KIT_CONVEX_URL=https://<prod-slug>.convex.cloud" > .env.production
#
# CI doesn't use `.env.production` — the `deploy` job in
# `.github/workflows/ci.yml` reads `VITE_KIT_CONVEX_URL` from the
# `VITE_KIT_CONVEX_URL` GitHub secret and passes it as a Docker build-arg,
# which is the source of truth for automated deploys. The
# `.env.production` + `scripts/deploy-prod.sh` pair exists so that a
# manual fallback deploy can't accidentally source `.env.local` (dev
# URL) and publish a prod SPA bundle pointed at the dev backend.

# ────────────────────────────────────────────────────────────────
# Convex (required for anything to work)
# ────────────────────────────────────────────────────────────────
# Frontend (Vite reads VITE_ prefix at build time)
VITE_KIT_CONVEX_URL=https://<your-project>.convex.cloud

# Convex CLI — `bunx convex dev` / `bunx convex deploy` read these
CONVEX_DEPLOYMENT=dev:<your-deployment-slug>
CONVEX_DEPLOY_KEY=<your-convex-deploy-key>

# Automatically populated by Convex CLI on first `convex dev`; do not edit.
# VITE_KIT_CONVEX_SITE_URL=https://<slug>.convex.site

# ────────────────────────────────────────────────────────────────
# Server runtime (picked up by the Hono server + Convex CLI)
# ────────────────────────────────────────────────────────────────
# Optional: "development" or "production" — switches API base URL in
# OpenAPI spec generation (default: production if unset).
# APP_ENV=development

# Port the Bun HTTP server binds to. Fly.io sets this to 3000 via
# Dockerfile ENV; override locally if 3000 is in use.
# PORT=3000

# Directory the SPA falls back to for unmatched routes. Useful for
# running the compiled binary against a non-default dist folder.
# STATIC_ROOT=./dist

# ────────────────────────────────────────────────────────────────
# Rate limiter (per-API-key token bucket on /api/v1/purchase/verify)
# See server/api/v1/rate-limit.ts for the full contract. These knobs
# tune burst protection; the Convex-side monthly plan quota enforces
# sustained usage separately.
# ────────────────────────────────────────────────────────────────
# Maximum burst size. Default: 600.
# RATE_LIMIT_CAPACITY=600
# Steady-state refill, tokens per second. Default: 10 (= 600 req/min).
# RATE_LIMIT_REFILL_PER_SEC=10
# Upper bound on the in-memory bucket store (LRU-evicts oldest when
# exceeded). Caps resident memory if a caller churns random API keys
# — apiKeyMiddleware only parses the Bearer header; database validation
# happens later in the Convex verify action, so this cap is the
# nearest defense. Default: 10000 (~1 MB). Minimum: 1.
# RATE_LIMIT_MAX_STORE=10000

# ────────────────────────────────────────────────────────────────
# Mixpanel (product analytics + retention dashboards at mixpanel.com).
# VITE_-prefixed → baked into the SPA bundle, so the value is public.
# Leave blank in `.env.local` to disable init in dev — that keeps
# local testing noise out of the prod Mixpanel project. Fill it only
# in `.env.production` (and the `VITE_KIT_MIXPANEL_TOKEN` GitHub secret).
# ────────────────────────────────────────────────────────────────
VITE_KIT_MIXPANEL_TOKEN=

# Override target docs site (defaults to https://openiap.dev).
# VITE_KIT_DOCS_URL=https://openiap.dev

# ────────────────────────────────────────────────────────────────
# Server error reporting (Sentry) — all optional. If SENTRY_DSN is
# unset, the server skips Sentry initialization entirely.
# ────────────────────────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_SEND_DEFAULT_PII=false
# Default: 0.05 (was 0.10). Error events are already sampled at 1.0 by
# default, independent of this knob — this only controls success-path
# trace volume. Raise temporarily during incidents for richer tracing.
# SENTRY_TRACES_SAMPLE_RATE=0.05
# SENTRY_ENABLE_LOGS=true

# ────────────────────────────────────────────────────────────────
# Sentry (SPA / browser). Separate project from the server —
# server bugs go to `openiap-kit-node`, UI bugs to `openiap-kit-react`.
# Must be VITE_-prefixed; these values are embedded into the built SPA
# at `bun run build` time and visible to the browser.
# ────────────────────────────────────────────────────────────────
# VITE_KIT_SENTRY_DSN=
# VITE_KIT_SENTRY_TRACES_SAMPLE_RATE=0.05

# ────────────────────────────────────────────────────────────────
# ⚠️  The following values are NOT read from .env.local.
# They must be set inside the Convex dashboard:
#   https://dashboard.convex.dev/d/<deployment>/settings/environment-variables
#
# They're listed here so new contributors know what to configure.
# ────────────────────────────────────────────────────────────────
#
#   Email OTP (Resend) — required for email sign-in
#     RESEND_API_KEY=re_********
#     RESEND_EMAIL_FROM="IAPKit <noreply@kit.openiap.dev>"
#
#   GitHub OAuth — required for `Continue with GitHub`
#     Register an OAuth app at https://github.com/settings/developers
#     Callback URL: https://<slug>.convex.site/api/auth/callback/github
#     AUTH_GITHUB_ID=Ov23********
#     AUTH_GITHUB_SECRET=ghp_********
