{
  "name": "@hyodotdev/openiap-kit",
  "private": true,
  "version": "1.1.0",
  "description": "IAPKit — receipt validation SaaS + dashboard + Convex backend, managed by OpenIAP, deployed to kit.openiap.dev",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "dev:server": "bun --watch ./server/server.ts",
    "dev:convex": "convex dev",
    "build": "vite build",
    "build:server": "bun build --compile ./server/server.ts --outfile openiap-kit-server",
    "build:all": "bun run build && bun run build:server",
    "start": "./openiap-kit-server",
    "typecheck": "tsc -p . --noEmit --pretty false",
    "lint": "run-s lint:tsc lint:eslint",
    "lint:tsc": "tsc -p . --noEmit --pretty false",
    "lint:eslint": "env NODE_OPTIONS=--max-old-space-size=4096 eslint ./src ./server ./convex --ext ts,tsx --report-unused-disable-directives --no-warn-ignored",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf node_modules bun.lock bun.lockb dist openiap-kit-server",
    "clean:cache": "rm -rf node_modules/.vite",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,json}\" \"server/**/*.{ts,json}\" \"convex/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,json}\" \"server/**/*.{ts,json}\" \"convex/**/*.{ts,json}\"",
    "smoke:server": "bun run build:all && ./scripts/smoke-server.sh",
    "precommit": "bunx lint-staged && bun run lint && bun run test && bun run smoke:server",
    "update-apple-certs": "node scripts/update-apple-certificates.js",
    "convex:deploy": "convex deploy",
    "deploy:prod": "bash scripts/deploy-prod.sh"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^1.6.0",
    "@auth/core": "^0.41.2",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/migrations": "^0.3.4",
    "@icons-pack/react-simple-icons": "^13.7.0",
    "@preact/signals-react": "^3.2.1",
    "@sentry/bun": "^10.26.0",
    "@sentry/react": "^10.49.0",
    "antd": "^6.1.0",
    "clsx": "^2.1.1",
    "convex": "^1.29.2",
    "googleapis": "^157.0.0",
    "hono": "^4.9.9",
    "hono-openapi": "^1.1.0",
    "lucide-react": "^0.577.0",
    "mixpanel-browser": "^2.72.0",
    "oslo": "^1.2.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.7.1",
    "remark-gfm": "^4.0.1",
    "resend": "^4.8.0",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.1.0",
    "tailwindcss-animate": "^1.0.7",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/bun": "^1.2.0",
    "@types/mixpanel-browser": "^2.59.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4",
    "autoprefixer": "~10",
    "dotenv": "^16.4.7",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.15.0",
    "jsdom": "^29",
    "lint-staged": "^16.1.5",
    "npm-run-all": "^4.1.5",
    "postcss": "~8",
    "prettier": "^3.5.3",
    "sharp": "^0.34.3",
    "tailwindcss": "~4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vitest": "^4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md,html}": [
      "bunx prettier --write"
    ]
  }
}
