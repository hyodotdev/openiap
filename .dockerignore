# Root .dockerignore — applies whenever a Dockerfile is built with the
# monorepo root as the build context (currently: packages/kit/Dockerfile,
# wired up in .github/workflows/deploy-kit.yml + packages/kit/scripts/deploy-prod.sh).
#
# Keep this file aggressive: every path listed here is *not* sent to the
# Docker daemon, which keeps build context small and prevents .env files
# from accidentally being baked into an image.

.git
.github
.husky
.vscode
.claude
.idea

# All node_modules across the workspace — `bun install` runs inside the
# image, so host-installed deps would just bloat the context.
**/node_modules

# Local build artifacts.
**/dist
**/build
packages/kit/openiap-kit-server
packages/google/openiap/build
packages/apple/.build

# Env files must never enter the build context. Vite vars come in via
# --build-arg from CI secrets; runtime secrets come from `flyctl secrets`
# / Convex dashboard. A stray .env.local would silently override.
**/.env
**/.env.*

# Other workspace packages we don't need for kit's image. Listing them
# explicitly is cheaper than walking them.
libraries
knowledge
scripts/agent
packages/docs/dist
