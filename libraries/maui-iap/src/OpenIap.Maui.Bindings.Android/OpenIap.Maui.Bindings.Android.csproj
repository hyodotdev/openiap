<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-android</TargetFramework>
    <SupportedOSPlatformVersion>24.0</SupportedOSPlatformVersion>
    <RootNamespace>Hyo.OpenIap.Maui.Bindings.Android</RootNamespace>
    <AssemblyName>Hyo.OpenIap.Maui.Bindings.Android</AssemblyName>
    <Nullable>enable</Nullable>
    <LangVersion>12.0</LangVersion>
    <IsBindingProject>true</IsBindingProject>
    <AndroidClassParser>class-parse</AndroidClassParser>
    <AndroidCodegenTarget>XAJavaInterop1</AndroidCodegenTarget>
    <!--
      CS0108/CS0109: Kotlin sealed-class subtype `_members` field hides parent's;
                     these are Xamarin.Android binding artifacts on Kotlin sealed
                     classes (e.g. OpenIapError) and are benign — the override is
                     deliberate to surface each subtype's own field set.
      BG86xx-BG88xx: known Java-binding noise about renamed/wrapped events.
    -->
    <!-- The binding csproj targets net9.0-android; generated calls reference
         APIs marked [SupportedOSPlatform("Android21.0")]. The codegen does not
         emit availability attributes on the generated wrappers so CA1416 fires
         on every JNI call site. They are safe at our minimum API 24. -->
    <!--
      BG8605: kotlinx.coroutines.flow.StateFlow types from OpenIapStore — not on
              the binding's classpath; the OpenIapMauiShim facade doesn't expose them.
      BG8A04: stale Metadata.xml hint paths (kept for forward-compat in case the
              AAR re-introduces those packages).
    -->
    <NoWarn>$(NoWarn);CS1591;CS1573;CS0108;CS0109;CA1416;BG8605;BG8606;BG8604;BG8700;BG8800;BG8401;BG8A04</NoWarn>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <!-- Bind the Play flavor of the Google package's openiap library. The
         Horizon flavor is API-equivalent for our needs (same dev.hyo.openiap
         package shape), so consumers get the Play binding by default; a sibling
         binding project can be added if/when Horizon-specific APIs require a
         separate surface. -->
    <AndroidLibrary Include="..\..\..\..\packages\google\openiap\build\outputs\aar\openiap-play-release.aar" Bind="true" />
  </ItemGroup>

  <ItemGroup>
    <TransformFile Include="Transforms\Metadata.xml" />
    <TransformFile Include="Transforms\EnumFields.xml" />
    <TransformFile Include="Transforms\EnumMethods.xml" />
  </ItemGroup>

</Project>
