<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:OpenIap.Maui.Example.Components"
             x:Class="OpenIap.Maui.Example.Pages.SubscriptionFlowPage"
             Title="Subscription Flow"
             BackgroundColor="White">

    <Grid>
        <ScrollView x:Name="ContentScroll" IsVisible="False">
            <VerticalStackLayout Padding="20" Spacing="16">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Subscription Flow"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1A1A1A" />
                    <Label Text="Recurring subscriptions with offer details and active-status checks"
                           FontSize="14"
                           TextColor="#5F6470" />
                </VerticalStackLayout>

                <Border Stroke="#E1E7EF" StrokeShape="RoundRectangle 12" Padding="14" BackgroundColor="#F7F9FC">
                    <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="Store Connection:" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label x:Name="ConnectionLabel" Text="❌ Disconnected" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Subscriptions list -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Available Subscriptions" FontSize="18" FontAttributes="Bold" TextColor="#1A1A1A" />
                    <Label x:Name="SubsCountLabel" FontSize="13" TextColor="#5F6470" />
                </VerticalStackLayout>
                <VerticalStackLayout x:Name="SubsContainer" Spacing="12" />

                <!-- Active subscriptions -->
                <VerticalStackLayout Spacing="6" Margin="0,8,0,0">
                    <Label Text="Active Subscriptions" FontSize="18" FontAttributes="Bold" TextColor="#1A1A1A" />
                    <Label x:Name="ActiveCountLabel" FontSize="13" TextColor="#5F6470" />
                </VerticalStackLayout>
                <VerticalStackLayout x:Name="ActiveContainer" Spacing="8" />
                <Button Text="Refresh active subscriptions"
                        BackgroundColor="#E5EAF1"
                        TextColor="#1A1A1A"
                        CornerRadius="8"
                        Padding="12,8"
                        HorizontalOptions="Start"
                        Clicked="OnRefreshActiveClicked" />
                <Button Text="🔧 Manage Subscriptions"
                        BackgroundColor="#1A1A1A"
                        TextColor="White"
                        CornerRadius="8"
                        Padding="14,10"
                        HorizontalOptions="Start"
                        Clicked="OnManageClicked" />

                <!-- Latest result -->
                <Border x:Name="ResultPanel" IsVisible="False" Stroke="#E1E7EF" StrokeShape="RoundRectangle 12" Padding="14" BackgroundColor="#FFFBE6">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Latest Status" FontAttributes="Bold" />
                        <Label x:Name="ResultLabel" />
                        <Label x:Name="LatestPurchaseHeader" Text="Latest Purchase" FontAttributes="Bold" Margin="0,8,0,0" IsVisible="False" />
                        <components:PurchaseSummaryRow x:Name="LatestPurchaseRow" IsVisible="False" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <components:Loading x:Name="LoadingView" Message="Connecting to Store..." />

        <Grid x:Name="DetailsOverlay" IsVisible="False" BackgroundColor="#80000000">
            <Border Margin="20" StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" Padding="20,16" ColumnDefinitions="*,Auto" BackgroundColor="#F7F9FC">
                        <Label Grid.Column="0" Text="Subscription Details" FontAttributes="Bold" FontSize="18" />
                        <Button Grid.Column="1" Text="✕" BackgroundColor="Transparent" TextColor="#666" Clicked="OnCloseDetailsClicked" />
                    </Grid>
                    <ScrollView Grid.Row="1" Padding="20">
                        <VerticalStackLayout x:Name="DetailsContent" Spacing="6" />
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
