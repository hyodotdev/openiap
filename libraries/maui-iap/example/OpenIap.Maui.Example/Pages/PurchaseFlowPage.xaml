<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:OpenIap.Maui.Example.Components"
             x:Class="OpenIap.Maui.Example.Pages.PurchaseFlowPage"
             Title="In-App Purchase Flow"
             BackgroundColor="White">

    <Grid>
        <ScrollView x:Name="ContentScroll" IsVisible="False">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- Header -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="In-App Purchase Flow"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1A1A1A" />
                    <Label Text="Testing consumable and non-consumable products"
                           FontSize="14"
                           TextColor="#5F6470" />
                </VerticalStackLayout>

                <!-- Connection status -->
                <Border Stroke="#E1E7EF" StrokeShape="RoundRectangle 12" Padding="14" BackgroundColor="#F7F9FC">
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Store Connection:" FontAttributes="Bold" />
                        <Label x:Name="ConnectionLabel" Text="❌ Disconnected" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Storefront panel -->
                <Border Stroke="#E1E7EF" StrokeShape="RoundRectangle 12" Padding="14" BackgroundColor="#F7F9FC">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="Storefront:" FontAttributes="Bold" />
                            <Label x:Name="StorefrontValueLabel" Text="Not available" />
                        </HorizontalStackLayout>
                        <Label x:Name="StorefrontErrorLabel"
                               IsVisible="False"
                               TextColor="#D32F2F"
                               FontSize="12" />
                        <Button x:Name="StorefrontRefreshButton"
                                Text="Refresh storefront"
                                BackgroundColor="#E5EAF1"
                                TextColor="#1A1A1A"
                                CornerRadius="8"
                                HorizontalOptions="Start"
                                Padding="12,6"
                                Clicked="OnRefreshStorefrontClicked" />
                    </VerticalStackLayout>
                </Border>

                <!-- Verification method picker -->
                <Border Stroke="#E1E7EF" StrokeShape="RoundRectangle 12" Padding="14" BackgroundColor="#F7F9FC">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Purchase Verification:" FontAttributes="Bold" />
                        <Button x:Name="VerificationButton"
                                Text="❌ None (Skip)"
                                BackgroundColor="#1A1A1A"
                                TextColor="White"
                                CornerRadius="8"
                                HorizontalOptions="Start"
                                Padding="14,8"
                                Clicked="OnChangeVerificationClicked" />
                        <Label Text="Tap to change"
                               FontSize="11"
                               TextColor="#888" />
                    </VerticalStackLayout>
                </Border>

                <!-- Products list -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Available Products" FontSize="18" FontAttributes="Bold" TextColor="#1A1A1A" />
                    <Label x:Name="ProductsCountLabel" FontSize="13" TextColor="#5F6470" />
                </VerticalStackLayout>
                <VerticalStackLayout x:Name="ProductsContainer" Spacing="12" />

                <!-- Available purchases -->
                <VerticalStackLayout Spacing="6" Margin="0,8,0,0">
                    <Label Text="Available Purchases" FontSize="18" FontAttributes="Bold" TextColor="#1A1A1A" />
                    <Label x:Name="PurchasesCountLabel" FontSize="13" TextColor="#5F6470" />
                </VerticalStackLayout>
                <VerticalStackLayout x:Name="PurchasesContainer" Spacing="0" />
                <Button x:Name="RefreshPurchasesButton"
                        Text="Refresh available purchases"
                        BackgroundColor="#E5EAF1"
                        TextColor="#1A1A1A"
                        CornerRadius="8"
                        Padding="12,8"
                        HorizontalOptions="Start"
                        Clicked="OnRefreshPurchasesClicked" />

                <!-- Latest status / latest purchase -->
                <Border x:Name="ResultPanel"
                        IsVisible="False"
                        Stroke="#E1E7EF"
                        StrokeShape="RoundRectangle 12"
                        Padding="14"
                        BackgroundColor="#FFFBE6">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Latest Status" FontAttributes="Bold" />
                        <Label x:Name="ResultLabel" />
                        <Label x:Name="LatestPurchaseHeader" Text="Latest Purchase" FontAttributes="Bold" Margin="0,8,0,0" IsVisible="False" />
                        <components:PurchaseSummaryRow x:Name="LatestPurchaseRow" IsVisible="False" />
                        <Button Text="📋 Copy Message"
                                BackgroundColor="#1A1A1A"
                                TextColor="White"
                                CornerRadius="8"
                                HorizontalOptions="Start"
                                Padding="12,6"
                                Clicked="OnCopyResultClicked" />
                    </VerticalStackLayout>
                </Border>

                <!-- App Transaction (iOS) -->
                <Button x:Name="AppTransactionButton"
                        Text="🔍 Check App Transaction (iOS 16+)"
                        BackgroundColor="#1A1A1A"
                        TextColor="White"
                        CornerRadius="10"
                        Padding="14,10"
                        HorizontalOptions="Start"
                        IsVisible="False"
                        Clicked="OnCheckAppTransactionClicked" />

                <!-- Instructions -->
                <Border Stroke="#E1E7EF" StrokeShape="RoundRectangle 12" Padding="14" BackgroundColor="#F7F9FC" Margin="0,8,0,0">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="How to test:" FontAttributes="Bold" />
                        <Label Text="1. Make sure you're signed in with a Sandbox account" />
                        <Label Text="2. Products must be configured in App Store Connect / Play Console" />
                        <Label Text="3. Tap &quot;Purchase&quot; to initiate the transaction" />
                        <Label Text="4. The transaction is processed via the PurchaseUpdated stream" />
                        <Label Text="5. Server-side receipt validation is recommended for production" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <components:Loading x:Name="LoadingView" Message="Connecting to Store..." />

        <!-- Product details overlay -->
        <Grid x:Name="ProductDetailsOverlay" IsVisible="False" BackgroundColor="#80000000">
            <Border Margin="20" StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" Padding="20,16" ColumnDefinitions="*,Auto" BackgroundColor="#F7F9FC">
                        <Label Grid.Column="0" Text="Product Details" FontAttributes="Bold" FontSize="18" />
                        <Button Grid.Column="1" Text="✕" BackgroundColor="Transparent" TextColor="#666" Clicked="OnCloseProductDetailsClicked" />
                    </Grid>
                    <ScrollView Grid.Row="1" Padding="20">
                        <VerticalStackLayout x:Name="ProductDetailsContent" Spacing="6" />
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>

        <!-- Purchase details overlay -->
        <Grid x:Name="PurchaseDetailsOverlay" IsVisible="False" BackgroundColor="#80000000">
            <Border Margin="20" StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" Padding="20,16" ColumnDefinitions="*,Auto" BackgroundColor="#F7F9FC">
                        <Label Grid.Column="0" Text="Purchase Details" FontAttributes="Bold" FontSize="18" />
                        <Button Grid.Column="1" Text="✕" BackgroundColor="Transparent" TextColor="#666" Clicked="OnClosePurchaseDetailsClicked" />
                    </Grid>
                    <ScrollView Grid.Row="1" Padding="20">
                        <components:PurchaseDetailsView x:Name="PurchaseDetailsView" />
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
