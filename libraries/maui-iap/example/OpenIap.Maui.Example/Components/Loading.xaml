<?xml version="1.0" encoding="UTF-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenIap.Maui.Example.Components.Loading">
    <Grid BackgroundColor="White">
        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
            <ActivityIndicator IsRunning="True" Color="#007AFF" HeightRequest="48" WidthRequest="48" />
            <Label x:Name="MessageLabel"
                   Text="Connecting to Store..."
                   FontSize="14"
                   TextColor="#666"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Grid>
</ContentView>
